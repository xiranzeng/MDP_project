def compute_bellman_residual(V, env):
    """计算 Bellman 残差"""
    TV = np.zeros(env.n_states)
    for s in range(env.n_states):
        best_value = float('inf')
        for a in range(env.n_actions):
            value = env.C[s, a]
            for ns in range(env.n_states):
                prob = env.P[s, a, ns]
                if prob > 0:
                    value += prob * env.gamma * V[ns]
            best_value = min(best_value, value)
        TV[s] = best_value
    return np.max(np.abs(V - TV))


def run_algorithm_multi_times(agent_class, env, n_runs=30):
    """多次运行算法，收集迭代次数"""
    results = []
    for run in range(n_runs):
        np.random.seed(run * 1000)
        try:
            agent = agent_class(env)
            start = time.time()
            _, values = agent.optimize(theta=1e-6)
            runtime = time.time() - start
            iterations = agent.round_num if hasattr(agent, 'round_num') else 0
            residual = compute_bellman_residual(values, env)
            results.append({
                'iterations': iterations,
                'runtime': runtime,
                'residual': residual,
                'success': True
            })
        except Exception as e:
            print(f"  Error: {e}")
            results.append({'iterations': np.nan, 'runtime': np.nan, 'residual': np.nan, 'success': False})
    return results


def paired_ttest(data1, data2):
    """配对 t 检验"""
    d1 = [x['iterations'] for x in data1 if not np.isnan(x['iterations'])]
    d2 = [x['iterations'] for x in data2 if not np.isnan(x['iterations'])]
    
    # 确保长度相同
    min_len = min(len(d1), len(d2))
    d1 = d1[:min_len]
    d2 = d2[:min_len]
    
    if len(d1) < 2:
        return {'p_value': np.nan, 'significant': False}
    
    t_stat, p_value = stats.ttest_rel(d1, d2)
    
    if p_value < 0.001:
        stars = '***'
    elif p_value < 0.01:
        stars = '**'
    elif p_value < 0.05:
        stars = '*'
    else:
        stars = 'ns'
    
    return {
        't_statistic': t_stat,
        'p_value': p_value,
        'significant': p_value < 0.05,
        'stars': stars,
        'mean_diff': np.mean(d1) - np.mean(d2)
    }


