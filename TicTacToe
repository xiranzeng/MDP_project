import numpy as np
from typing import Tuple, List, Dict
from collections import deque

class TicTacToeEnv:
    """k×k 井字棋环境"""
    
    def __init__(self, k: int = 3):
        self.k = k
        self.board_size = k * k
        
        self.PLAYER1 = 1  # AI
        self.PLAYER2 = 2  # 随机玩家
        self.EMPTY = 0
        
        self._build_state_space()
        
    def _build_state_space(self):
        """构建状态空间"""
        self.all_states = []
        self.state_to_idx = {}
        
        empty_board = tuple([self.EMPTY] * self.board_size)
        self.state_to_idx[empty_board] = 0
        self.all_states.append(empty_board)
        
        queue = deque([empty_board])
        
        while queue:
            board = queue.popleft()
            
            if self._is_game_over(board):
                continue
                
            current_player = self._get_current_player(board)
            
            for pos in range(self.board_size):
                if board[pos] == self.EMPTY:
                    new_board_list = list(board)
                    new_board_list[pos] = current_player
                    new_board = tuple(new_board_list)
                    
                    if new_board not in self.state_to_idx:
                        self.state_to_idx[new_board] = len(self.all_states)
                        self.all_states.append(new_board)
                        queue.append(new_board)
        
        self.n_states = len(self.all_states)
        self.n_actions = self.board_size
        
        # 构建转移概率和成本
        self.P = np.zeros((self.n_states, self.n_actions, self.n_states))
        self.C = np.zeros((self.n_states, self.n_actions))
        
        self._build_transitions()
        
    def _get_current_player(self, board):
        """判断当前轮到哪个玩家"""
        count1 = board.count(self.PLAYER1)
        count2 = board.count(self.PLAYER2)
        
        if count1 == count2:
            return self.PLAYER1
        else:
            return self.PLAYER2
    
    def _check_win(self, board, player):
        """检查指定玩家是否获胜"""
        # 检查行
        for i in range(self.k):
            if all(board[i * self.k + j] == player for j in range(self.k)):
                return True
        
        # 检查列
        for j in range(self.k):
            if all(board[i * self.k + j] == player for i in range(self.k)):
                return True
        
        # 检查主对角线
        if all(board[i * self.k + i] == player for i in range(self.k)):
            return True
        
        # 检查副对角线
        if all(board[i * self.k + (self.k - 1 - i)] == player for i in range(self.k)):
            return True
        
        return False
    
    def _is_game_over(self, board):
        """检查游戏是否结束"""
        if self._check_win(board, self.PLAYER1) or self._check_win(board, self.PLAYER2):
            return True
        
        if all(cell != self.EMPTY for cell in board):
            return True
        
        return False
    
    def _get_reward(self, board, action, next_board):
        """计算奖励"""
        if self._check_win(next_board, self.PLAYER1):
            return 1.0
        elif self._check_win(next_board, self.PLAYER2):
            return -1.0
        else:
            return 0.0
    
    def _build_transitions(self):
        """构建转移概率矩阵"""
        for s_idx, board in enumerate(self.all_states):
            if self._is_game_over(board):
                for a in range(self.n_actions):
                    self.P[s_idx, a, s_idx] = 1.0
                    self.C[s_idx, a] = 0.0
                continue
            
            current_player = self._get_current_player(board)
            
            for a in range(self.n_actions):
                if board[a] != self.EMPTY:
                    self.P[s_idx, a, s_idx] = 1.0
                    self.C[s_idx, a] = 0.0
                    continue
                
                if current_player == self.PLAYER1:
                    # AI的回合：确定性转移
                    new_board_list = list(board)
                    new_board_list[a] = self.PLAYER1
                    new_board = tuple(new_board_list)
                    next_idx = self.state_to_idx[new_board]
                    self.P[s_idx, a, next_idx] = 1.0
                    self.C[s_idx, a] = self._get_reward(board, a, new_board)
                
                else:
                    # 随机玩家的回合：均匀随机选择
                    empty_positions = [pos for pos in range(self.board_size) if board[pos] == self.EMPTY]
                    
                    if not empty_positions:
                        self.P[s_idx, a, s_idx] = 1.0
                        self.C[s_idx, a] = 0.0
                        continue
                    
                    prob_each = 1.0 / len(empty_positions)
                    
                    for pos in empty_positions:
                        new_board_list = list(board)
                        new_board_list[pos] = self.PLAYER2
                        new_board = tuple(new_board_list)
                        next_idx = self.state_to_idx[new_board]
                        self.P[s_idx, a, next_idx] += prob_each
                    
                    # 计算期望奖励
                    expected_reward = 0.0
                    for pos in empty_positions:
                        new_board_list = list(board)
                        new_board_list[pos] = self.PLAYER2
                        new_board = tuple(new_board_list)
                        expected_reward += prob_each * self._get_reward(board, a, new_board)
                    self.C[s_idx, a] = expected_reward
    
    def render(self, board):
        """打印棋盘"""
        for i in range(self.k):
            row = []
            for j in range(self.k):
                cell = board[i * self.k + j]
                if cell == self.EMPTY:
                    row.append('.')
                elif cell == self.PLAYER1:
                    row.append('X')
                else:
                    row.append('O')
            print(' '.join(row))
        print()


class StandardValueIteration:
    """
    Approach 1: 标准值迭代 (Classic Value Iteration)
    
    算法描述:
    y_i^{k+1} = min_{j∈A_i} {c_j + γ p_j^T y^k}, ∀i
    
    特点:
    - 使用上一轮迭代的所有状态值来更新当前轮
    - 所有状态同步更新
    - 保证收敛到最优值函数
    """
    
    def __init__(self, env, gamma=0.99, theta=1e-6):
        self.env = env
        self.gamma = gamma
        self.theta = theta
        self.V = np.zeros(env.n_states)  # 初始值函数
        self.history = []  # 记录每轮的误差
        
    def _compute_best_value(self, s, V):
        """
        计算状态 s 的最优值
        
        Args:
            s: 状态索引
            V: 当前值函数
            
        Returns:
            best_action: 最优动作
            best_value: 最优值
        """
        best_value = float('-inf')
        best_action = 0
        
        for a in range(self.env.n_actions):
            # 计算动作 a 的值
            value = 0
            for next_s in range(self.env.n_states):
                prob = self.env.P[s, a, next_s]
                if prob > 0:
                    value += prob * (self.env.C[s, a] + self.gamma * V[next_s])
            
            # 因为是最大化奖励，所以取最大值
            if value > best_value:
                best_value = value
                best_action = a
                
        return best_action, best_value
    
    def solve(self, max_iter=10000, verbose=True):
        """
        使用标准值迭代求解最优策略
        
        Args:
            max_iter: 最大迭代次数
            verbose: 是否打印进度
            
        Returns:
            policy: 最优策略
            V: 最优值函数
            iterations: 实际迭代次数
            history: 每轮误差历史
        """
        iteration = 0
        self.history = []
        
        if verbose:
            print("=" * 60)
            print("Approach 1: 标准值迭代 (Classic Value Iteration)")
            print("=" * 60)
            print(f"状态数: {self.env.n_states}")
            print(f"动作数: {self.env.n_actions}")
            print(f"折扣因子 γ: {self.gamma}")
            print(f"收敛阈值 θ: {self.theta}")
            print()
        
        while iteration < max_iter:
            # 使用上一轮的值函数 V 来计算新的值函数 V_new
            V_new = np.zeros(self.env.n_states)
            delta = 0
            
            # 对所有状态进行同步更新
            for s in range(self.env.n_states):
                _, best_value = self._compute_best_value(s, self.V)
                V_new[s] = best_value
                
                # 计算变化量
                state_delta = np.abs(best_value - self.V[s])
                if state_delta > delta:
                    delta = state_delta
            
            # 记录历史
            self.history.append(delta)
            
            # 更新值函数
            self.V = V_new
            
            if verbose and (iteration % 10 == 0 or delta < self.theta):
                print(f"迭代 {iteration:4d}: delta = {delta:.8f}")
            
            # 检查收敛
            if delta < self.theta:
                if verbose:
                    print(f"\n✓ 收敛于第 {iteration} 次迭代")
                break
                
            iteration += 1
        
        if iteration >= max_iter:
            if verbose:
                print(f"\n⚠ 达到最大迭代次数 {max_iter}，未完全收敛")
        
        # 提取最优策略
        policy = np.zeros(self.env.n_states, dtype=int)
        for s in range(self.env.n_states):
            policy[s], _ = self._compute_best_value(s, self.V)
            
        return policy, self.V, iteration, self.history


def evaluate_policy(env, policy, n_games=100, verbose=False):
    """评估策略性能"""
    wins = 0
    losses = 0
    draws = 0
    
    for game in range(n_games):
        current_board = tuple([env.EMPTY] * env.board_size)
        
        while not env._is_game_over(current_board):
            current_player = env._get_current_player(current_board)
            state_idx = env.state_to_idx[current_board]
            
            if current_player == env.PLAYER1:
                action = policy[state_idx]
            else:
                empty_positions = [pos for pos in range(env.board_size) if current_board[pos] == env.EMPTY]
                if not empty_positions:
                    break
                action = np.random.choice(empty_positions)
            
            new_board_list = list(current_board)
            new_board_list[action] = current_player
            current_board = tuple(new_board_list)
        
        if env._check_win(current_board, env.PLAYER1):
            wins += 1
        elif env._check_win(current_board, env.PLAYER2):
            losses += 1
        else:
            draws += 1
    
    if verbose:
        print(f"\n{'='*40}")
        print(f"策略评估 ({n_games} 局)")
        print(f"{'='*40}")
        print(f"胜场: {wins} ({wins/n_games*100:.1f}%)")
        print(f"负场: {losses} ({losses/n_games*100:.1f}%)")
        print(f"平局: {draws} ({draws/n_games*100:.1f}%)")
        print(f"{'='*40}")
    
    return wins, losses, draws


def play_game(env, policy, render=True):
    """演示一局游戏"""
    current_board = tuple([env.EMPTY] * env.board_size)
    
    if render:
        print("\n" + "=" * 40)
        print("新游戏开始！")
        print("AI (X) vs 随机玩家 (O)")
        print("=" * 40)
        print()
        env.render(current_board)
    
    move_count = 0
    
    while not env._is_game_over(current_board):
        current_player = env._get_current_player(current_board)
        state_idx = env.state_to_idx[current_board]
        
        if current_player == env.PLAYER1:
            action = policy[state_idx]
            if render:
                print(f"第 {move_count//2 + 1} 轮 - AI 选择位置: {action}")
        else:
            empty_positions = [pos for pos in range(env.board_size) if current_board[pos] == env.EMPTY]
            if not empty_positions:
                break
            action = np.random.choice(empty_positions)
            if render:
                print(f"第 {move_count//2 + 1} 轮 - 随机玩家选择位置: {action}")
        
        new_board_list = list(current_board)
        new_board_list[action] = current_player
        current_board = tuple(new_board_list)
        move_count += 1
        
        if render:
            env.render(current_board)
    
    # 输出结果
    if render:
        print("-" * 40)
        if env._check_win(current_board, env.PLAYER1):
            print("🎉 AI 获胜！ 🎉")
        elif env._check_win(current_board, env.PLAYER2):
            print("😢 随机玩家 获胜！")
        else:
            print("🤝 平局！")
        print("=" * 40)
    
    return current_board


def plot_convergence(history):
    """绘制收敛曲线"""
    import matplotlib.pyplot as plt
    
    plt.figure(figsize=(10, 6))
    plt.semilogy(history, linewidth=2)
    plt.xlabel('迭代次数', fontsize=12)
    plt.ylabel('误差 (delta)', fontsize=12)
    plt.title('标准值迭代 (Approach 1) 收敛曲线', fontsize=14)
    plt.grid(True, alpha=0.3)
    plt.tight_layout()
    plt.show()


